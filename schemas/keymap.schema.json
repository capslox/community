{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/capslox/community@main/schemas/keymap.schema.json",
  "title": "Capslox Keymap Configuration",
  "description": "Schema for keymap.jsonc — the Capslox keyboard remapping configuration file.",
  "type": "object",
  "required": [
    "version",
    "layers"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference (ignored by the engine)."
    },
    "version": {
      "type": "string",
      "pattern": "^[1-9]\\d*(\\.[0-9]+)?$",
      "description": "Schema version in MAJOR.MINOR format (e.g. \"1.0\", \"2.0\"). Single-digit like \"2\" is accepted and treated as \"2.0\". MAJOR must be >= 1."
    },
    "custom_modifiers": {
      "type": "object",
      "description": "Map of physical key name → custom modifier declaration. String shorthand: alias only (tap defaults to key name, timeout 200ms). Object form: { \"alias\": \"cx\", \"tap\": \"esc\", \"timeout_ms\": 300 }. Declaring a key here provides a default mod_tap fallback — no explicit mod_tap binding needed.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "description": "Alias name (string shorthand). Tap defaults to key name, timeout 200ms."
          },
          {
            "type": "object",
            "required": ["alias"],
            "additionalProperties": false,
            "properties": {
              "alias": { "type": "string", "description": "Modifier alias name." },
              "tap": { "description": "Tap action (string key syntax or action object). Defaults to the physical key name." },
              "timeout_ms": { "type": "integer", "minimum": 1, "default": 200, "description": "Mod-tap timeout in milliseconds." }
            }
          }
        ]
      }
    },
    "vars": {
      "type": "object",
      "description": "User-defined variables for DRY config authoring. Each key maps a name to any JSON value. Reference with { \"$ref\": \"/vars/<name>\" } elsewhere in the config.",
      "additionalProperties": true
    },
    "layers": {
      "type": "array",
      "description": "Ordered list of layers. First matching binding wins (top layer first).",
      "items": {
        "$ref": "#/$defs/Layer"
      },
      "minItems": 1
    },
    "fs_allow": {
      "type": "array",
      "description": "Filesystem paths that shell_action commands are allowed to access.",
      "items": {
        "type": "string"
      }
    },
    "key_sequence_timeout_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Auto-reset key sequence state after N ms of inactivity. Omit for unlimited (Vim-style)."
    }
  },
  "$defs": {
    "Layer": {
      "type": "object",
      "required": [
        "id",
        "on_miss",
        "bindings"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique layer identifier."
        },
        "name": {
          "type": "string",
          "description": "Human-readable layer name (optional)."
        },
        "activation": {
          "$ref": "#/$defs/LayerActivation",
          "description": "How this layer is activated. Defaults to \"base\"."
        },
        "on_miss": {
          "$ref": "#/$defs/MissBehavior",
          "description": "What happens when a key has no binding in this layer."
        },
        "propagate_modifiers": {
          "type": "boolean",
          "default": true,
          "description": "Whether OS modifiers (shift, alt, etc.) are propagated through this layer's bindings."
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether this layer is active. Disabled layers are skipped."
        },
        "bindings": {
          "type": "object",
          "description": "Map of trigger key (e.g. \"cx-h\") → Binding.",
          "additionalProperties": {
            "$ref": "#/$defs/Binding"
          }
        }
      }
    },
    "LayerActivation": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "base"
            }
          },
          "description": "Always-active base layer."
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "manual"
            }
          },
          "description": "Layer activated/deactivated by layer_push/layer_pop/layer_toggle actions."
        },
        {
          "type": "object",
          "required": [
            "type",
            "bundle_ids"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "auto_app"
            },
            "bundle_ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "description": "App bundle IDs that activate this layer (supports dot-boundary wildcards like \"com.jetbrains.*\")."
            }
          },
          "description": "Layer automatically activated when the frontmost app matches any bundle ID."
        }
      ]
    },
    "MissBehavior": {
      "type": "string",
      "enum": [
        "continue",
        "block",
        "pass_to_os"
      ],
      "description": "Behavior when a key has no binding in this layer. \"continue\" = check next layer, \"block\" = swallow the key, \"pass_to_os\" = send to OS."
    },
    "Binding": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(continue|block|pass_to_os|noop|(\\()?([a-z0-9_\\[\\]/=,.;']+(-[a-z0-9_\\[\\]/=,.;']+)*)(\\*[1-9][0-9]{0,2})?( ([a-z0-9_\\[\\]/=,.;']+(-[a-z0-9_\\[\\]/=,.;']+)*)(\\*[1-9][0-9]{0,2})?)*(\\)\\*[1-9][0-9]{0,2})?)$",
          "description": "String shorthand: directive keyword or key syntax. Directives: \"continue\" (fall through), \"block\" (swallow), \"pass_to_os\" (send to OS). Key syntax: [modifier-]key[ [modifier-]key]... with optional *N repeat (1-999). Modifiers: ctrl, shift, alt/opt, cmd/win/meta/super, or custom. Keys: a-z, 0-9, space, enter, tab, esc, backspace, delete, caps, up/down/left/right, home/end/pageup/pagedown, f1-f20, [ ] / = , . ; ', minus, backslash, backtick, kp_0-kp_9, kp_enter/kp_plus/kp_minus/kp_multiply/kp_divide/kp_decimal/kp_equal/kp_clear. Examples: \"cmd-shift-a\", \"left\", \"ctrl-[ b\", \"alt-left*5\", \"continue\"."
        },
        {
          "$ref": "#/$defs/BindingDirectiveObject"
        },
        {
          "$ref": "#/$defs/BindingModTapObject"
        },
        {
          "$ref": "#/$defs/BindingLongPressObject"
        },
        {
          "$ref": "#/$defs/BindingComplexObject"
        },
        {
          "$ref": "#/$defs/ActionObject"
        }
      ],
      "description": "A binding maps a trigger key to an action. Forms: (1) string shorthand — \"cmd-c\", \"continue\", \"block\", \"pass_to_os\", \"noop\"; (2) action object — {\"action\": \"send_keys\", \"keys\": \"cmd-c\"}, which is sugar for {\"type\": \"action\", \"action\": \"send_keys\", ...} with the redundant \"type\" omitted; (3) temporal binding — {\"type\": \"mod_tap\", ...} / {\"type\": \"long_press\", ...}; (4) complex binding — {\"type\": \"complex\", \"trigger\": \"double_tap\", ...}. The engine also accepts the explicit {\"type\": \"action\", ...} form at runtime, but the sugar form is canonical."
    },
    "BindingDirectiveObject": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["continue", "block", "pass_to_os"]
        }
      },
      "description": "Directive binding (key-level on_miss override). \"continue\" = fall through, \"block\" = swallow, \"pass_to_os\" = send to OS."
    },
    "BindingModTapObject": {
      "type": "object",
      "required": [
        "type",
        "tap"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "mod_tap"
        },
        "tap": {
          "$ref": "#/$defs/Action",
          "description": "Action to fire on tap (short press). The hold action activates the key as a modifier."
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 200,
          "description": "Max duration (ms) for a tap vs hold decision. Default: 200."
        }
      },
      "description": "Modifier-tap: hold = use key as modifier, tap = fire action."
    },
    "BindingLongPressObject": {
      "type": "object",
      "required": [
        "type",
        "short",
        "long"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "long_press"
        },
        "short": {
          "$ref": "#/$defs/Action",
          "description": "Action for short press."
        },
        "long": {
          "$ref": "#/$defs/Action",
          "description": "Action for long press (held past threshold)."
        },
        "threshold_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 500,
          "description": "Duration (ms) before switching from short to long. Default: 500."
        }
      },
      "description": "Long-press: different actions based on press duration."
    },
    "BindingComplexObject": {
      "type": "object",
      "required": [
        "type",
        "trigger",
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "complex"
        },
        "trigger": {
          "$ref": "#/$defs/TriggerType",
          "description": "Trigger condition: \"down\" (key press), \"up\" (key release), \"hold\" (held past threshold), \"double_tap\" (two quick presses)."
        },
        "action": {
          "$ref": "#/$defs/Action",
          "description": "Action to fire when the trigger condition is met."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses",
          "description": "Optional condition clauses that must all be true for this binding to trigger."
        }
      },
      "description": "Complex binding: trigger an action based on a specific key event pattern (double-tap, hold, etc.)."
    },
    "Action": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(noop|(\\()?([a-z0-9_\\[\\]/=,.;']+(-[a-z0-9_\\[\\]/=,.;']+)*)(\\*[1-9][0-9]{0,2})?( ([a-z0-9_\\[\\]/=,.;']+(-[a-z0-9_\\[\\]/=,.;']+)*)(\\*[1-9][0-9]{0,2})?)*(\\)\\*[1-9][0-9]{0,2})?)$",
          "description": "Key syntax shorthand or \"noop\". Key syntax: [modifier-]key[ [modifier-]key]... with optional *N repeat (1-999). Modifiers: ctrl, shift, alt/opt, cmd/win/meta/super, or custom. Keys: a-z, 0-9, space, enter, tab, esc, backspace, delete, caps, up/down/left/right, home/end/pageup/pagedown, f1-f20, [ ] / = , . ; ', minus, backslash, backtick, kp_0-kp_9, kp_enter/kp_plus/kp_minus/kp_multiply/kp_divide/kp_decimal/kp_equal/kp_clear. Examples: \"left\", \"cmd-shift-a\", \"ctrl-[ b\", \"noop\"."
        },
        {
          "$ref": "#/$defs/ActionSendKeysObject"
        },
        {
          "$ref": "#/$defs/ActionActionSequenceObject"
        },
        {
          "$ref": "#/$defs/ActionToggleCapsLockObject"
        },
        {
          "$ref": "#/$defs/ActionShowPreferencesObject"
        },
        {
          "$ref": "#/$defs/ActionShowCheatSheetObject"
        },
        {
          "$ref": "#/$defs/ActionEditKeymapObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardCopyObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardCutObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardPasteObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardPastePlainObject"
        },
        {
          "$ref": "#/$defs/ActionBindWindowObject"
        },
        {
          "$ref": "#/$defs/ActionActivateWindowObject"
        },
        {
          "$ref": "#/$defs/ActionHotstringObject"
        },
        {
          "$ref": "#/$defs/ActionShowAppInfoObject"
        },
        {
          "$ref": "#/$defs/ActionHiddenShowKeyboardMapObject"
        },
        {
          "$ref": "#/$defs/ActionLayerPushObject"
        },
        {
          "$ref": "#/$defs/ActionLayerPopObject"
        },
        {
          "$ref": "#/$defs/ActionLayerToggleObject"
        },
        {
          "$ref": "#/$defs/ActionLayerSwapObject"
        },
        {
          "$ref": "#/$defs/ActionShellActionObject"
        },
        {
          "$ref": "#/$defs/ActionNoOpObject"
        }
      ],
      "description": "An action describes WHAT to do. Can be a string shorthand or a typed object with \"action\" discriminator."
    },
    "ActionObject": {
      "description": "Any action type used directly as a binding (without an explicit Binding wrapper). Matches objects whose \"action\" field is an action discriminator, not a binding type.",
      "oneOf": [
        {
          "$ref": "#/$defs/ActionSendKeysObject"
        },
        {
          "$ref": "#/$defs/ActionActionSequenceObject"
        },
        {
          "$ref": "#/$defs/ActionToggleCapsLockObject"
        },
        {
          "$ref": "#/$defs/ActionShowPreferencesObject"
        },
        {
          "$ref": "#/$defs/ActionShowCheatSheetObject"
        },
        {
          "$ref": "#/$defs/ActionEditKeymapObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardCopyObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardCutObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardPasteObject"
        },
        {
          "$ref": "#/$defs/ActionClipboardPastePlainObject"
        },
        {
          "$ref": "#/$defs/ActionBindWindowObject"
        },
        {
          "$ref": "#/$defs/ActionActivateWindowObject"
        },
        {
          "$ref": "#/$defs/ActionHotstringObject"
        },
        {
          "$ref": "#/$defs/ActionShowAppInfoObject"
        },
        {
          "$ref": "#/$defs/ActionHiddenShowKeyboardMapObject"
        },
        {
          "$ref": "#/$defs/ActionLayerPushObject"
        },
        {
          "$ref": "#/$defs/ActionLayerPopObject"
        },
        {
          "$ref": "#/$defs/ActionLayerToggleObject"
        },
        {
          "$ref": "#/$defs/ActionLayerSwapObject"
        },
        {
          "$ref": "#/$defs/ActionShellActionObject"
        },
        {
          "$ref": "#/$defs/ActionNoOpObject"
        }
      ]
    },
    "ActionSendKeysObject": {
      "type": "object",
      "required": [
        "action",
        "keys"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "send_keys"
        },
        "keys": {
          "type": "string",
          "pattern": "^(\\()?([a-z0-9_\\[\\]/=,.;']+(-[a-z0-9_\\[\\]/=,.;']+)*)(\\*[1-9][0-9]{0,2})?( ([a-z0-9_\\[\\]/=,.;']+(-[a-z0-9_\\[\\]/=,.;']+)*)(\\*[1-9][0-9]{0,2})?)*(\\)\\*[1-9][0-9]{0,2})?$",
          "description": "Key syntax string: [modifier-]key[ [modifier-]key]... with optional *N repeat (1-999). Examples: \"cmd-c\", \"ctrl-[ b\", \"alt-left*5\"."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Send a key sequence (one or more key combos with optional repeat)."
    },
    "ActionActionSequenceObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "action_sequence"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Action"
          },
          "description": "Ordered list of actions to execute sequentially."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Execute multiple actions in sequence."
    },
    "ActionToggleCapsLockObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "toggle_caps_lock"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Toggle CapsLock state."
    },
    "ActionShowPreferencesObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "show_preferences"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Open the Capslox preferences window."
    },
    "ActionShowCheatSheetObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "show_cheat_sheet"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Show the keyboard shortcut cheat sheet."
    },
    "ActionEditKeymapObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "edit_keymap"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Open the keymap editor."
    },
    "ActionClipboardCopyObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "clipboard_copy"
        },
        "slot": {
          "type": "string",
          "default": "",
          "description": "Clipboard slot identifier."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Copy to an extra clipboard slot."
    },
    "ActionClipboardCutObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "clipboard_cut"
        },
        "slot": {
          "type": "string",
          "default": "",
          "description": "Clipboard slot identifier."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Cut to an extra clipboard slot."
    },
    "ActionClipboardPasteObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "clipboard_paste"
        },
        "slot": {
          "type": "string",
          "default": "",
          "description": "Clipboard slot identifier."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Paste from an extra clipboard slot."
    },
    "ActionClipboardPastePlainObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "clipboard_paste_plain"
        },
        "slot": {
          "type": "string",
          "default": "",
          "description": "Clipboard slot identifier."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Paste plain text from an extra clipboard slot (strips formatting)."
    },
    "ActionBindWindowObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "bind_window"
        },
        "slot": {
          "type": "string",
          "default": "",
          "description": "Window binding slot identifier."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Bind the current window to a slot for quick switching."
    },
    "ActionActivateWindowObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "activate_window"
        },
        "slot": {
          "type": "string",
          "default": "",
          "description": "Window binding slot identifier."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Activate (switch to) the window bound to a slot."
    },
    "ActionHotstringObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "hotstring"
        },
        "text": {
          "type": "string",
          "default": "",
          "description": "Text to type. Empty triggers hotstring input mode."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Hotstring: type text or activate hotstring input mode."
    },
    "ActionShowAppInfoObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "show_app_info"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Show current app/window info in a modal."
    },
    "ActionHiddenShowKeyboardMapObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "hidden_show_keyboard_map"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Debug: show keyboard map."
    },
    "ActionLayerPushObject": {
      "type": "object",
      "required": [
        "action",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "layer_push"
        },
        "target": {
          "type": "string",
          "description": "Layer ID to push onto the stack."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Push a layer onto the active stack."
    },
    "ActionLayerPopObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "layer_pop"
        },
        "target": {
          "type": "string",
          "description": "Layer ID to pop. Omit to pop the topmost layer."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Pop a layer from the active stack."
    },
    "ActionLayerToggleObject": {
      "type": "object",
      "required": [
        "action",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "layer_toggle"
        },
        "target": {
          "type": "string",
          "description": "Layer ID to toggle on/off."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Toggle a layer on or off."
    },
    "ActionLayerSwapObject": {
      "type": "object",
      "required": [
        "action",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "layer_swap"
        },
        "target": {
          "type": "string",
          "description": "Layer ID to swap to (replaces current topmost layer)."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Swap the topmost active layer for another."
    },
    "ActionShellActionObject": {
      "type": "object",
      "required": [
        "action",
        "command"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "shell_action"
        },
        "command": {
          "type": "string",
          "description": "Shell command to execute. The command's working directory is restricted by fs_allow."
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "Execute a shell command."
    },
    "ActionNoOpObject": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "const": "no_op"
        },
        "when": {
          "$ref": "#/$defs/WhenClauses"
        }
      },
      "description": "No-op: consume the key but do nothing (useful in when-clauses to disable a binding for specific apps)."
    },
    "WhenClauses": {
      "oneOf": [
        {
          "$ref": "#/$defs/WhenClause"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WhenClause"
          },
          "minItems": 1,
          "description": "Multiple conditional overrides, checked in order."
        }
      ],
      "description": "Conditional overrides: when the frontmost app matches, use a different action."
    },
    "WhenClause": {
      "type": "object",
      "required": [
        "apps",
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "apps": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "description": "Literal list of app bundle IDs (supports dot-boundary wildcards like \"com.jetbrains.*\")."
            },
            {
              "$ref": "#/$defs/RefObject"
            }
          ],
          "description": "App bundle IDs to match. Can be a literal array or a { \"$ref\": \"/vars/<name>\" } reference."
        },
        "action": {
          "$ref": "#/$defs/Action",
          "description": "Action to use when the frontmost app matches."
        }
      },
      "description": "A single conditional override: when the frontmost app matches, use this action instead."
    },
    "RefObject": {
      "type": "object",
      "required": [
        "$ref"
      ],
      "additionalProperties": false,
      "properties": {
        "$ref": {
          "type": "string",
          "pattern": "^#?/",
          "description": "JSON Pointer to a value in the same document (e.g. \"/vars/apps_emacs_keybindings\"). Leading '#' is optional."
        }
      },
      "description": "A $ref object that references another value in the document via JSON Pointer (RFC 6901)."
    }
  }
}
